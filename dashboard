<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TrainingByNiki — Klienten-Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@600;700;800&family=IBM+Plex+Mono:wght@400;500;600&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0E0E10; --panel:#17171A; --panel2:#1E1E22; --ink:#F5F4F1; --ink-soft:#8A8A90;
  --orange:#FF5A1F; --amber:#FFB020; --rust:#C8401D; --green:#3FA66A; --teal:#2A8A7A;
  --line:rgba(255,255,255,0.09); --grid:rgba(255,90,31,0.04);
}
*{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
html,body{margin:0;padding:0;}
body{
  background:var(--bg); color:var(--ink);
  font-family:'Inter', sans-serif; -webkit-font-smoothing:antialiased; min-height:100vh;
}

/* ===== TOP NAV ===== */
.topbar{
  background:rgba(14,14,16,0.96); border-bottom:1px solid var(--line);
  position:sticky; top:0; z-index:100; backdrop-filter:blur(8px);
  display:flex; align-items:center; gap:0; overflow-x:auto;
  padding:0 16px;
}
.topbar-logo{
  display:flex; align-items:center; gap:10px;
  padding:10px 14px 10px 0; margin-right:4px;
  border-right:1px solid var(--line); flex-shrink:0;
}
.topbar-logo img{width:36px; height:36px;}
.topbar-logo .brand{font-family:'Big Shoulders Display'; font-weight:800; font-size:16px; letter-spacing:0.03em; color:var(--ink); white-space:nowrap;}
.nav-tab{
  padding:14px 16px; font-family:'IBM Plex Mono', monospace; font-size:11px;
  font-weight:600; letter-spacing:0.12em; text-transform:uppercase;
  color:var(--ink-soft); border:none; background:transparent; cursor:pointer;
  white-space:nowrap; border-bottom:2px solid transparent; flex-shrink:0;
  transition:color .15s, border-color .15s;
}
.nav-tab:hover{color:var(--ink);}
.nav-tab.active{color:var(--orange); border-bottom-color:var(--orange);}

/* ===== PAGE CONTAINER ===== */
.page{display:none; padding:24px 16px 60px; max-width:1060px; margin:0 auto;}
.page.active{display:block;}

/* ===== COMMON PANEL ===== */
.card{background:var(--panel); border:1px solid var(--line); position:relative; padding:22px 20px 22px;}
.card::before{content:''; position:absolute; top:-1px; left:-1px; width:12px; height:12px; border-top:2px solid var(--orange); border-left:2px solid var(--orange);}
.card::after{content:''; position:absolute; bottom:-1px; right:-1px; width:12px; height:12px; border-bottom:2px solid var(--orange); border-right:2px solid var(--orange);}
.card-label{font-family:'IBM Plex Mono', monospace; font-size:10px; letter-spacing:0.14em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:16px;}

/* ===== FIELD ===== */
.field{margin-bottom:14px;}
.field label{display:block; font-size:12.5px; font-weight:600; margin-bottom:6px;}
.field .hint{font-family:'IBM Plex Mono'; font-size:10.5px; color:var(--ink-soft); font-weight:400; margin-left:5px;}
input[type=text], input[type=number], input[type=date], select, textarea{
  width:100%; border:none; border-bottom:1.5px solid var(--line); background:transparent;
  padding:8px 2px; font-family:'IBM Plex Mono', monospace; font-size:14px; color:var(--ink);
  outline:none; transition:border-color .15s; -webkit-appearance:none; appearance:none; border-radius:0; resize:none;
}
select{cursor:pointer;} select option{background:var(--panel); color:var(--ink);}
input:focus, select:focus, textarea:focus{border-bottom-color:var(--orange);}
input::placeholder, textarea::placeholder{color:#4A4A52;}
.row2{display:grid; grid-template-columns:1fr 1fr; gap:14px;}

/* ===== SEG / BUTTONS ===== */
.seg{display:flex; border:1px solid var(--line); margin-top:4px; flex-wrap:wrap;}
.seg button{
  flex:1; min-width:60px; padding:8px 4px; font-family:'Inter'; font-size:12px; font-weight:600;
  background:transparent; border:none; border-right:1px solid var(--line); cursor:pointer; color:var(--ink-soft);
}
.seg button:last-child{border-right:none;}
.seg button.active{background:var(--orange); color:#0E0E10;}
.seg-desc{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft); margin-top:6px; line-height:1.5;}

.slider-row{display:flex; align-items:center; gap:10px; margin-top:6px;}
input[type=range]{flex:1; height:2px; accent-color:var(--orange);}
.slider-val{font-family:'IBM Plex Mono'; font-size:12px; min-width:96px; text-align:right; font-weight:600;}

.btn{
  display:block; width:100%; background:var(--orange); color:#0E0E10; border:none; padding:12px;
  font-family:'IBM Plex Mono'; font-weight:600; font-size:12.5px; letter-spacing:0.07em;
  text-transform:uppercase; cursor:pointer; transition:background .15s, transform .1s;
}
.btn:hover{background:var(--amber);} .btn:active{transform:scale(0.99);}
.btn.outline{background:transparent; border:1.5px solid var(--orange); color:var(--orange);}
.btn.outline:hover{background:var(--orange); color:#0E0E10;}
.btn.sm{padding:8px; font-size:11px;}
.btn.ghost{background:transparent; border:1px solid var(--line); color:var(--ink-soft);}
.btn.ghost:hover{border-color:var(--orange); color:var(--orange); background:transparent;}
.btn-row{display:flex; gap:10px; margin-top:12px;}
.btn-row .btn{flex:1;}

/* ===== STATUS / BANNERS ===== */
.note{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft); margin-top:12px; line-height:1.6; border-top:1px solid var(--line); padding-top:10px;}
.note.ok{color:var(--green); border-top:none; padding-top:0;}
.note.warn{color:var(--amber); border-top:none; padding-top:0;}
.banner{border:1px solid; padding:11px 14px; font-size:12.5px; line-height:1.5; margin-bottom:14px;}
.banner.red{border-color:var(--rust); background:rgba(200,64,29,.12); color:#FFCFBA;}
.banner.amber{border-color:var(--amber); background:rgba(255,176,32,.10); color:#FFE6B0;}
.empty-state{color:var(--ink-soft); font-size:13px; font-family:'IBM Plex Mono'; line-height:1.6; padding:28px 0; text-align:center;}
.disabled-note{color:var(--ink-soft); font-size:12.5px; font-family:'IBM Plex Mono'; padding:14px; text-align:center; border:1px dashed var(--line);}

/* ===== LAYOUT GRIDS ===== */
.grid2{display:grid; grid-template-columns:1fr 1fr; gap:18px; align-items:start;}
.grid3{display:grid; grid-template-columns:repeat(3,1fr); gap:18px;}
@media(max-width:820px){.grid2,.grid3{grid-template-columns:1fr;}}
.mt{margin-top:18px;}

/* ===== DASHBOARD ===== */
.dash-hero{
  background:var(--panel);
  border:1px solid var(--line);
  padding:28px 26px;
  position:relative;
  overflow:hidden;
  margin-bottom:18px;
}
.dash-hero::before{content:''; position:absolute; top:-1px; left:-1px; width:12px; height:12px; border-top:2px solid var(--orange); border-left:2px solid var(--orange);}
.dash-hero::after{content:''; position:absolute; bottom:-1px; right:-1px; width:12px; height:12px; border-bottom:2px solid var(--orange); border-right:2px solid var(--orange);}
.dash-hero-bg{
  position:absolute; right:-20px; top:50%; transform:translateY(-50%);
  width:200px; height:200px; opacity:0.04; pointer-events:none;
}
.dash-hero-bg img{width:100%; height:100%;}
.dash-eyebrow{font-family:'IBM Plex Mono'; font-size:11px; letter-spacing:0.15em; text-transform:uppercase; color:var(--orange); margin-bottom:6px;}
.dash-hero h2{font-family:'Big Shoulders Display'; font-weight:800; font-size:clamp(28px,5vw,44px); text-transform:uppercase; margin:0; line-height:0.95; color:var(--ink);}
.dash-hero .sub{color:var(--ink-soft); font-size:13px; margin-top:10px;}

.kpi-row{display:grid; grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px; margin-bottom:18px;}
.kpi-block{background:var(--panel); border:1px solid var(--line); padding:16px 18px;}
.kpi-block .kpi-label{font-family:'IBM Plex Mono'; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:6px;}
.kpi-block .kpi-num{font-family:'Big Shoulders Display'; font-weight:800; font-size:36px; color:var(--orange); line-height:1;}
.kpi-block .kpi-sub{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft); margin-top:3px;}

.client-cards{display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:14px; margin-top:18px;}
.client-card{
  background:var(--panel); border:1px solid var(--line); padding:18px 16px; cursor:pointer;
  transition:border-color .15s, background .15s; position:relative;
}
.client-card:hover{border-color:var(--orange); background:var(--panel2);}
.client-card .cc-name{font-family:'Big Shoulders Display'; font-weight:800; font-size:22px; text-transform:uppercase; color:var(--ink); line-height:1;}
.client-card .cc-meta{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft); margin-top:4px; margin-bottom:14px;}
.client-card .cc-stats{display:grid; grid-template-columns:1fr 1fr; gap:8px;}
.cc-stat{background:var(--panel2); padding:8px 10px;}
.cc-stat .cc-stat-label{font-family:'IBM Plex Mono'; font-size:10px; letter-spacing:0.08em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:2px;}
.cc-stat .cc-stat-val{font-family:'IBM Plex Mono'; font-weight:600; font-size:14px;}
.cc-actions{display:flex; gap:8px; margin-top:12px;}
.cc-actions button{flex:1; padding:7px; font-family:'IBM Plex Mono'; font-size:10.5px; letter-spacing:0.06em; text-transform:uppercase; cursor:pointer; border:1px solid var(--line); background:transparent; color:var(--ink-soft);}
.cc-actions button:hover{border-color:var(--orange); color:var(--orange);}
.phase-pill{
  display:inline-block; font-family:'IBM Plex Mono'; font-size:10px; letter-spacing:0.1em;
  text-transform:uppercase; padding:3px 8px; margin-bottom:8px;
}
.phase-pill.p1{background:rgba(200,64,29,.25); color:#FFCFBA;}
.phase-pill.p2{background:rgba(255,176,32,.2); color:#FFE6B0;}
.phase-pill.p3{background:rgba(63,166,106,.2); color:#A8F0C6;}
.phase-pill.p4{background:rgba(42,138,122,.2); color:#A0E8DF;}

/* ===== TRACKER ===== */
.vh-head{display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:10px; margin-bottom:16px; padding-bottom:12px; border-bottom:1px dashed var(--line);}
.vh-head .name{font-family:'Big Shoulders Display'; font-weight:800; font-size:26px; color:var(--orange); text-transform:uppercase; line-height:1;}
.vh-head .meta{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft); margin-top:4px;}
.phase-select-mini{font-family:'IBM Plex Mono'; font-size:11px; background:var(--panel2); border:1px solid var(--line); color:var(--ink); padding:6px 8px;}
.stat-grid{display:grid; grid-template-columns:repeat(auto-fit,minmax(220px,1fr)); gap:14px; margin-bottom:8px;}
.stat-block{background:var(--panel2); border:1px solid var(--line); padding:14px 16px;}
.stat-block .sb-title{font-family:'IBM Plex Mono'; font-size:10.5px; letter-spacing:0.1em; text-transform:uppercase; color:var(--ink-soft); margin-bottom:8px;}
.stat-block .num-row{display:flex; align-items:baseline; gap:10px;}
.stat-block .num{font-family:'Big Shoulders Display'; font-weight:800; font-size:34px; color:var(--ink); line-height:1;}
.stat-block .unit{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft);}
.stat-block .delta{font-family:'IBM Plex Mono'; font-size:11px; margin-top:4px;}
.delta.pos{color:var(--green);} .delta.neg{color:var(--rust);} .delta.neutral{color:var(--amber);}
.chart-wrap svg{width:100%; height:auto; display:block;}
.chart-label-row{display:flex; justify-content:space-between; font-family:'IBM Plex Mono'; font-size:10px; color:var(--ink-soft); margin-top:4px;}
.entries-title{font-family:'IBM Plex Mono'; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink); margin:20px 0 10px;}
.entry-card{background:var(--panel2); border:1px solid var(--line); padding:12px 14px; margin-bottom:8px; position:relative;}
.entry-card .del-btn{position:absolute; top:8px; right:8px; background:transparent; border:none; color:var(--ink-soft); font-size:14px; cursor:pointer; padding:2px 6px;}
.entry-card .del-btn:hover{color:var(--rust);}
.entry-card .e-date{font-family:'IBM Plex Mono'; font-weight:600; font-size:12.5px; color:var(--orange); margin-bottom:6px;}
.entry-tags{display:flex; gap:8px; flex-wrap:wrap; margin-bottom:6px;}
.e-tag{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink); background:rgba(255,255,255,.05); padding:3px 7px; border:1px solid var(--line);}
.e-note{font-size:12px; color:var(--ink-soft); line-height:1.5;}
.file-label{display:block; text-align:center; border:1.5px dashed var(--line); color:var(--ink-soft); font-family:'IBM Plex Mono'; font-size:11px; padding:10px; cursor:pointer; margin-top:8px;}
.file-label:hover{border-color:var(--orange); color:var(--orange);}

/* ===== PLAN GENERATOR ===== */
.ex-card{background:var(--panel2); border:1px solid var(--line); padding:12px 14px; margin-bottom:8px;}
.ex-card .ex-name{font-size:13px; font-weight:700; margin-bottom:5px;}
.ex-dose-row{display:flex; gap:12px; flex-wrap:wrap; font-family:'IBM Plex Mono'; font-size:11px; color:var(--amber); margin-bottom:5px;}
.ex-dose-row .lbl{color:var(--ink-soft); font-size:10.5px;}
.ex-cue{font-size:12px; color:var(--ink-soft); line-height:1.5;}
.ex-equip{display:inline-block; font-family:'IBM Plex Mono'; font-size:10px; color:var(--ink-soft); border:1px solid var(--line); padding:2px 6px; margin-top:6px; letter-spacing:.03em;}
.section-title{font-family:'IBM Plex Mono'; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink); margin:18px 0 8px;}
.section-title .n{color:var(--orange);}
.info-box{background:var(--panel2); border-left:3px solid var(--orange); padding:11px 14px; margin-top:16px; font-size:12.5px; line-height:1.6;}
.info-box .ib-title{font-family:'IBM Plex Mono'; font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color:var(--orange); margin-bottom:6px;}
.info-box ul{margin:4px 0 0; padding-left:18px;}
.info-box li{margin-bottom:3px; color:var(--ink-soft);}
.plan-head .pname{font-family:'Big Shoulders Display'; font-weight:800; font-size:24px; color:var(--orange); text-transform:uppercase; line-height:1;}
.plan-head .pmeta{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft); margin-top:4px; margin-bottom:14px;}

/* ===== MACRO ===== */
.kcal-display{text-align:center; padding:6px 0 16px; border-bottom:1px dashed var(--line); margin-bottom:16px;}
.kcal-display .num{font-family:'Big Shoulders Display'; font-weight:800; font-size:52px; color:var(--orange); line-height:1;}
.kcal-display .lbl{font-family:'IBM Plex Mono'; font-size:11px; letter-spacing:0.12em; text-transform:uppercase; color:var(--ink-soft); margin-top:4px;}
.stat-line{display:flex; justify-content:space-between; align-items:baseline; padding:7px 0; border-bottom:1px solid var(--line); font-size:13px;}
.stat-line .k{color:var(--ink-soft);}
.stat-line .v{font-family:'IBM Plex Mono'; font-weight:600;}
.bar-stack{display:flex; height:30px; width:100%; margin:16px 0 4px; border:1px solid var(--line); overflow:hidden;}
.bar-seg{transition:width .6s cubic-bezier(.2,.8,.2,1);}
.macro-list{margin-top:12px;}
.macro-row{display:grid; grid-template-columns:12px 1fr auto auto; gap:10px; align-items:center; padding:8px 0; border-bottom:1px solid var(--line);}
.macro-row:last-child{border-bottom:none;}
.dot{width:9px;height:9px;border-radius:2px;}
.macro-name{font-size:13px; font-weight:600;}
.macro-g{font-family:'IBM Plex Mono'; font-size:13px; font-weight:600; text-align:right;}
.macro-pct{font-family:'IBM Plex Mono'; font-size:11px; color:var(--ink-soft); min-width:32px; text-align:right;}

footer{text-align:center; margin-top:32px; font-family:'IBM Plex Mono'; font-size:10px; color:var(--ink-soft); letter-spacing:.03em; line-height:1.8; max-width:1060px; margin-left:auto; margin-right:auto; padding:0 16px 24px;}
</style>
</head>
<body>

<!-- TOP NAV -->
<div class="topbar">
  <div class="topbar-logo">
    <img src="data:image/png;base64," alt="Logo">
    <span class="brand">TrainingByNiki</span>
  </div>
  <button class="nav-tab active" data-tab="dash">Übersicht</button>
  <button class="nav-tab" data-tab="tracker">Tracker</button>
  <button class="nav-tab" data-tab="plan">Trainingsplan</button>
  <button class="nav-tab" data-tab="macro">Kalorien</button>
</div>

<!-- ======================================================= -->
<!-- TAB: DASHBOARD                                          -->
<!-- ======================================================= -->
<div class="page active" id="tab-dash">
  <div class="dash-hero">
    <div class="dash-hero-bg"><img src="data:image/png;base64," alt=""></div>
    <div class="dash-eyebrow">Dein Coach-Cockpit</div>
    <h2>Willkommen<br>zurück</h2>
    <div class="sub">Alle Klient:innen, Verläufe und Tools auf einen Blick.</div>
  </div>

  <div class="kpi-row" id="dashKpi"></div>

  <div class="grid2">
    <div class="card">
      <div class="card-label">Neue Klient:in anlegen</div>
      <div class="field"><label>Name</label><input type="text" id="dashNewName" placeholder="z. B. Sandra M."></div>
      <div class="field">
        <label>Körperbereich</label>
        <select id="dashNewRegion">
          <option value="schulter">Schulter</option><option value="knie">Knie</option>
          <option value="ruecken">Rücken / LWS</option><option value="huefte">Hüfte</option>
          <option value="nacken">Nacken / HWS</option><option value="sprunggelenk">Sprunggelenk</option>
          <option value="ganzkorper">Ganzkörper / Allgemein</option>
        </select>
      </div>
      <div class="field">
        <label>Start-Phase</label>
        <select id="dashNewPhase">
          <option value="phase1">Phase 1 — Akut</option><option value="phase2">Phase 2 — Mobilität</option>
          <option value="phase3">Phase 3 — Kraftaufbau</option><option value="phase4">Phase 4 — Return to Activity</option>
        </select>
      </div>
      <button class="btn" id="dashAddClientBtn">Klient:in anlegen</button>
      <div class="note" id="dashAddNote"></div>
    </div>
    <div class="card">
      <div class="card-label">Daten / Backup</div>
      <button class="btn outline sm" id="dashExportBtn">Alle Daten exportieren (.json)</button>
      <label class="file-label" for="dashImportFile" style="margin-top:10px;">Daten importieren (.json)</label>
      <input type="file" id="dashImportFile" accept="application/json" style="display:none;">
      <div class="note" id="dashStorageNote" style="margin-top:14px;"></div>
    </div>
  </div>

  <div id="clientCards" class="client-cards"></div>
</div>

<!-- ======================================================= -->
<!-- TAB: TRACKER                                            -->
<!-- ======================================================= -->
<div class="page" id="tab-tracker">
  <div class="grid2">
    <div>
      <div class="card">
        <div class="card-label">Klient:in</div>
        <div class="field"><label>Auswählen</label><select id="trkClientSelect"><option value="">— bitte wählen —</option></select></div>
        <div id="deleteClientWrap" style="display:none; margin-top:8px;">
          <button class="btn ghost sm" id="trkDeleteClientBtn">Klient:in löschen</button>
        </div>
      </div>
      <div class="card mt" id="trkEntryCard">
        <div class="card-label">Neuer Eintrag</div>
        <div class="disabled-note">Bitte zuerst Klient:in auswählen.</div>
      </div>
    </div>
    <div class="card" id="trkVerlaufCard">
      <div class="card-label">Verlauf</div>
      <div class="empty-state">— Klient:in auswählen —</div>
    </div>
  </div>
</div>

<!-- ======================================================= -->
<!-- TAB: TRAININGSPLAN                                      -->
<!-- ======================================================= -->
<div class="page" id="tab-plan">
  <div class="grid2">
    <div class="card">
      <div class="card-label">Eingaben</div>
      <div class="field"><label>Klient:in <span class="hint">optional</span></label><input type="text" id="planClientName" placeholder="z. B. Sandra M."></div>
      <div class="field">
        <label>Körperbereich</label>
        <select id="planRegion">
          <option value="schulter">Schulter</option><option value="knie">Knie</option>
          <option value="ruecken">Rücken / LWS</option><option value="huefte">Hüfte</option>
          <option value="nacken">Nacken / HWS</option><option value="sprunggelenk">Sprunggelenk</option>
          <option value="ganzkorper">Ganzkörper / Allgemein</option>
        </select>
      </div>
      <div class="field">
        <label>Reha-Phase</label>
        <div class="seg" id="planPhaseSeg">
          <button data-val="phase1" class="active">Phase 1</button>
          <button data-val="phase2">Phase 2</button>
          <button data-val="phase3">Phase 3</button>
          <button data-val="phase4">Phase 4</button>
        </div>
        <div class="seg-desc" id="planPhaseDesc"></div>
      </div>
      <div class="field">
        <label>Schmerzlevel <span class="hint">0–10</span></label>
        <div class="slider-row">
          <input type="range" id="planPain" min="0" max="10" value="2">
          <span class="slider-val" id="planPainVal">2 / 10</span>
        </div>
      </div>
      <div class="field">
        <label>Freigabe vorhanden?</label>
        <div class="seg" id="planClearanceSeg">
          <button data-val="ja" class="active">Ja</button>
          <button data-val="nein">Nein</button>
        </div>
      </div>
      <div class="field">
        <label>Trainingsfrequenz</label>
        <div class="seg" id="planFreqSeg">
          <button data-val="2">2×/Woche</button>
