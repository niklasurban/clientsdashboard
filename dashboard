    note
  };
  if(!state.entries[trkCurrentClientId]) state.entries[trkCurrentClientId]=[];
  state.entries[trkCurrentClientId].push(entry);
  await saveState();
  const n=document.getElementById('trkSaveNote'); n.style.display='block'; n.className='note ok'; n.textContent='✓ Gespeichert.';
  setTimeout(()=>{ n.style.display='none'; },2000);
  trkRenderEntryForm(); trkRenderVerlauf(); renderDash();
}

function buildSVG(pts, color){
  const W=600,H=150,px=16,py=18;
  if(!pts.length) return '';
  if(pts.length===1) return `<svg viewBox="0 0 ${W} ${H}"><circle cx="${W/2}" cy="${H/2}" r="4" fill="${color}"/></svg>`;
  const vals=pts.map(p=>p.value); let mn=Math.min(...vals),mx=Math.max(...vals);
  if(mn===mx){mn-=1;mx+=1;}
  const xs=(W-2*px)/(pts.length-1);
  const coords=pts.map((p,i)=>({x:px+i*xs, y:py+(1-(p.value-mn)/(mx-mn))*(H-2*py)}));
  const d=coords.map((c,i)=>(i===0?'M':'L')+c.x.toFixed(1)+','+c.y.toFixed(1)).join(' ');
  const dots=coords.map(c=>`<circle cx="${c.x.toFixed(1)}" cy="${c.y.toFixed(1)}" r="3.5" fill="${color}"/>`).join('');
  return `<svg viewBox="0 0 ${W} ${H}"><path d="${d}" fill="none" stroke="${color}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="cpath"/>${dots}</svg>`;
}

function animCharts(el){ el.querySelectorAll('.cpath').forEach(p=>{ try{ const l=p.getTotalLength(); p.style.strokeDasharray=l; p.style.strokeDashoffset=l; p.getBoundingClientRect(); p.style.transition='stroke-dashoffset .8s cubic-bezier(.2,.8,.2,1)'; requestAnimationFrame(()=>{p.style.strokeDashoffset=0;}); }catch(e){} }); }

function deltaHtml(first,last,dec,lib){
  if(first===null||first===undefined) return '<div class="delta neutral">Erster Wert</div>';
  const d=last-first; let cls='neutral';
  if(lib===true) cls=d<0?'pos':(d>0?'neg':'neutral');
  if(lib===false) cls=d>0?'pos':(d<0?'neg':'neutral');
  return `<div class="delta ${cls}">Δ seit Start: ${d>0?'+':''}${fmtN(d,dec)}</div>`;
}

function trkRenderVerlauf(){
