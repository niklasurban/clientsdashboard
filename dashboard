let planPhase='phase1', planClearance='ja', planFreq='3';

function planSegBind(id, callback){
  document.querySelectorAll('#'+id+' button').forEach(b=>{
    b.addEventListener('click',()=>{
      document.querySelectorAll('#'+id+' button').forEach(x=>x.classList.remove('active'));
      b.classList.add('active'); callback(b.dataset.val);
    });
  });
}

planSegBind('planPhaseSeg', v=>{ planPhase=v; document.getElementById('planPhaseDesc').textContent=PHASE_INFO[v].desc; });
planSegBind('planClearanceSeg', v=>{ planClearance=v; });
planSegBind('planFreqSeg', v=>{ planFreq=v; });
document.getElementById('planPhaseDesc').textContent = PHASE_INFO[planPhase].desc;

const planPainSlider=document.getElementById('planPain'), planPainVal=document.getElementById('planPainVal');
function paintPlanPain(){ const v=parseInt(planPainSlider.value); let c=v<=3?'var(--green)':v<=6?'var(--amber)':'var(--rust)'; planPainVal.textContent=v+' / 10'; planPainVal.style.color=c; }
planPainSlider.addEventListener('input',paintPlanPain); paintPlanPain();

document.getElementById('planGenBtn').addEventListener('click', ()=>{
  const region=document.getElementById('planRegion').value;
  const clientName=document.getElementById('planClientName').value.trim();
  const pain=parseInt(planPainSlider.value);
  const equip=['bw'];
  if(document.getElementById('planEqBand').checked) equip.push('band');
  if(document.getElementById('planEqDumbbell').checked) equip.push('dumbbell');
  if(document.getElementById('planEqCable').checked) equip.push('cable');
  const pool=DB[region][planPhase];
  function fslot(s){ const sp=pool.filter(e=>e.slot===s); const f=sp.filter(e=>equip.includes(e.eq)); return f.length?f:sp; }
  const warmup=fslot('warmup'), main=fslot('main'), cooldown=fslot('cooldown');
  let banners='';
  if(planClearance==='nein') banners+=`<div class="banner red"><b>Keine ärztliche/physiotherapeutische Freigabe angegeben.</b> Empfehlungen dienen nur als Orientierung.</div>`;
  if(pain>=7) banners+=`<div class="banner red"><b>Hohes Schmerzniveau (${pain}/10).</b> Belastung pausieren, Rücksprache empfohlen.</div>`;
  else if(pain>=4) banners+=`<div class="banner amber"><b>Erhöhtes Schmerzniveau (${pain}/10).</b> Intensität ggf. reduzieren.</div>`;
  function exCard(e){ return `<div class="ex-card"><div class="ex-name">${esc(e.n)}</div><div class="ex-dose-row"><span><span class="lbl">Dosierung:</span> ${esc(e.dose)}</span>${e.tempo&&e.tempo!=='–'?`<span><span class="lbl">Tempo:</span> ${esc(e.tempo)}</span>`:''} ${e.rest&&e.rest!=='–'?`<span><span class="lbl">Pause:</span> ${esc(e.rest)}</span>`:''}</div><div class="ex-cue">${esc(e.cue)}</div><span class="ex-equip">${EQUIP_LABELS[e.eq]}</span></div>`; }
  const html=`
    ${banners}
    <div class="plan-head"><div class="pname">${clientName?esc(clientName):'Trainingsplan'}</div><div class="pmeta">${REGION_LABELS[region]} · ${PHASE_INFO[planPhase].label} · ${planFreq}×/Woche</div></div>
    <div class="section-title"><span class="n">01</span> Aufwärmen</div>${warmup.map(exCard).join('')}
    <div class="section-title"><span class="n">02</span> Hauptteil</div>${main.map(exCard).join('')}
    <div class="section-title"><span class="n">03</span> Cool-down</div>${cooldown.map(exCard).join('')}
    <div class="info-box"><div class="ib-title">Abbruchkriterien</div><ul><li>Scharfer, stechender oder plötzlich zunehmender Schmerz</li><li>Schmerz > 5/10 während der Übung</li><li>Zunehmende Schwellung nach Belastung</li><li>Taubheit, Kribbeln oder Ausstrahlung</li></ul></div>
    <div class="info-box"><div class="ib-title">Progressionskriterium</div>${esc(PHASE_INFO[planPhase].nextCriteria)}</div>
    <button class="btn outline sm" id="planCopyBtn" style="margin-top:16px;">Plan kopieren</button>
  `;
  const rc=document.getElementById('planResultCard'); rc.innerHTML='<div class="card-label">Trainingsplan</div>'+html;
  document.getElementById('planCopyBtn').addEventListener('click',()=>{
    let txt=`TRAININGBYNIKI — TRAININGSPLAN\n${'–'.repeat(36)}\n${clientName?'Klient:in: '+clientName+'\n':''}Region: ${REGION_LABELS[region]}\n${PHASE_INFO[planPhase].label} · ${planFreq}×/Woche\n\nAUFWÄRMEN\n`;
    warmup.forEach(e=>{ txt+=`• ${e.n} — ${e.dose}\n  ${e.cue}\n`; });
    txt+=`\nHAUPTTEIL\n`; main.forEach(e=>{ txt+=`• ${e.n} — ${e.dose}\n  ${e.cue}\n`; });
    txt+=`\nCOOL-DOWN\n`; cooldown.forEach(e=>{ txt+=`• ${e.n} — ${e.dose}\n  ${e.cue}\n`; });
    txt+=`\nHinweis: Kein Ersatz für ärztliche/physiotherapeutische Diagnostik.`;
    navigator.clipboard.writeText(txt).then(()=>{ const b=document.getElementById('planCopyBtn'); b.textContent='✓ Kopiert'; b.style.background='var(--green)'; b.style.borderColor='var(--green)'; b.style.color='#0E0E10'; setTimeout(()=>{ b.textContent='Plan kopieren'; b.style.background=''; b.style.borderColor=''; b.style.color=''; },1800); });
  });
});

function prefillPlan(name, region, phase){
  goToTab('plan', null);
  document.getElementById('planClientName').value=name;
  document.getElementById('planRegion').value=region;
  document.querySelectorAll('#planPhaseSeg button').forEach(b=>{ b.classList.remove('active'); if(b.dataset.val===phase) b.classList.add('active'); });
  planPhase=phase;
  document.getElementById('planPhaseDesc').textContent=PHASE_INFO[phase].desc;
}

/* ============================================================
   MACRO TAB
   ============================================================ */
let macroGender='m', macroGoal='maintain';
function macroSegBind(id,cb){ document.querySelectorAll('#'+id+' button').forEach(b=>{ b.addEventListener('click',()=>{ document.querySelectorAll('#'+id+' button').forEach(x=>x.classList.remove('active')); b.classList.add('active'); cb(b.dataset.val); }); }); }
macroSegBind('macroGenderSeg',v=>{ macroGender=v; });
macroSegBind('macroGoalSeg',v=>{
  macroGoal=v;
  const f=document.getElementById('macroGoalPctField'),s=document.getElementById('macroGoalPct'),lbl=document.getElementById('macroGoalPctLabel'),vv=document.getElementById('macroGoalPctVal');
  if(v==='maintain'){ f.style.display='none'; }
  else { f.style.display='block'; lbl.textContent=v==='cut'?'Defizit':'Überschuss'; s.min=v==='cut'?10:5; s.max=v==='cut'?30:20; s.value=v==='cut'?20:10; vv.textContent=s.value+'%'; }
});
document.getElementById('macroGoalPct').addEventListener('input',e=>{ document.getElementById('macroGoalPctVal').textContent=e.target.value+'%'; });
document.getElementById('macroProtein').addEventListener('input',e=>{ document.getElementById('macroProteinVal').textContent=parseFloat(e.target.value).toFixed(1); });
document.getElementById('macroFat').addEventListener('input',e=>{ document.getElementById('macroFatVal').textContent=parseFloat(e.target.value).toFixed(1); });

function animNum(el,to){ const t0=performance.now(),dur=700; function tick(now){ const p=Math.min(1,(now-t0)/dur),e2=1-Math.pow(1-p,3); el.textContent=Math.round(to*e2).toLocaleString('de-DE'); if(p<1)requestAnimationFrame(tick); } requestAnimationFrame(tick); }

document.getElementById('macroCalcBtn').addEventListener('click',()=>{
  const age=parseFloat(document.getElementById('macroAge').value);
  const height=parseFloat(document.getElementById('macroHeight').value);
  const weight=parseFloat(document.getElementById('macroWeight').value);
  const activity=parseFloat(document.getElementById('macroActivity').value);
  const rc=document.getElementById('macroResultCard'); rc.innerHTML='<div class="card-label">Ergebnis</div>';
  if(!age||!height||!weight){ rc.innerHTML+='<div class="empty-state" style="color:var(--rust);">Bitte Alter, Größe und Gewicht ausfüllen.</div>'; return; }
  const bmr=macroGender==='m'?(10*weight+6.25*height-5*age+5):(10*weight+6.25*height-5*age-161);
  const tdee=bmr*activity;
  let target=tdee,pct=0;
  if(macroGoal==='cut'){ pct=parseFloat(document.getElementById('macroGoalPct').value); target=tdee*(1-pct/100); }
  if(macroGoal==='bulk'){ pct=parseFloat(document.getElementById('macroGoalPct').value); target=tdee*(1+pct/100); }
  let proteinG=parseFloat(document.getElementById('macroProtein').value)*weight;
  let fatG=parseFloat(document.getElementById('macroFat').value)*weight;
  let warn='';
  if(proteinG*4+fatG*9>target){ const sc=target/(proteinG*4+fatG*9)*0.9; proteinG*=sc; fatG*=sc; warn='Protein- und Fettvorgaben wurden proportional reduziert.'; }
  const carbG=(target-proteinG*4-fatG*9)/4;
  const pP=Math.round(proteinG*4/target*100),cP=Math.round(carbG*4/target*100),fP=Math.round(fatG*9/target*100);
  const goalLabel=macroGoal==='cut'?`Abnehmen (–${pct}%)`:macroGoal==='bulk'?`Aufbau (+${pct}%)`:'Halten';
  rc.innerHTML+=`<div class="card-label">Ergebnis</div>
    <div class="kcal-display"><div class="num" id="macroNum">0</div><div class="lbl">kcal / Tag · ${goalLabel}</div></div>
    <div class="stat-line"><span class="k">Grundumsatz (BMR)</span><span class="v">${Math.round(bmr).toLocaleString('de-DE')} kcal</span></div>
    <div class="stat-line"><span class="k">Gesamtumsatz (TDEE)</span><span class="v">${Math.round(tdee).toLocaleString('de-DE')} kcal</span></div>
    <div class="bar-stack"><div class="bar-seg" style="width:${pP}%;background:#FF5A1F;"></div><div class="bar-seg" style="width:${cP}%;background:#FFB020;"></div><div class="bar-seg" style="width:${fP}%;background:#C8401D;"></div></div>
    <div class="macro-list">
      <div class="macro-row"><span class="dot" style="background:#FF5A1F;"></span><span class="macro-name">Protein</span><span class="macro-g" id="mPG">–</span><span class="macro-pct">${pP}%</span></div>
      <div class="macro-row"><span class="dot" style="background:#FFB020;"></span><span class="macro-name">Kohlenhydrate</span><span class="macro-g" id="mCG">–</span><span class="macro-pct">${cP}%</span></div>
      <div class="macro-row"><span class="dot" style="background:#C8401D;"></span><span class="macro-name">Fett</span><span class="macro-g" id="mFG">–</span><span class="macro-pct">${fP}%</span></div>
    </div>
    ${warn?`<div class="note warn">${warn}</div>`:''}
    <button class="btn outline sm" id="macroCopyBtn" style="margin-top:16px;">In Zwischenablage kopieren</button>
  `;
  animNum(document.getElementById('macroNum'),target);
  setTimeout(()=>{ document.getElementById('mPG').textContent=Math.round(proteinG)+' g'; document.getElementById('mCG').textContent=Math.round(carbG)+' g'; document.getElementById('mFG').textContent=Math.round(fatG)+' g'; },300);
  document.getElementById('macroCopyBtn').addEventListener('click',()=>{
    const txt=`TRAININGBYNIKI — ERNÄHRUNGS-REPORT\n${'–'.repeat(36)}\nZiel: ${goalLabel}\nZielkalorien: ${Math.round(target).toLocaleString('de-DE')} kcal/Tag\nBMR: ${Math.round(bmr).toLocaleString('de-DE')} kcal\nTDEE: ${Math.round(tdee).toLocaleString('de-DE')} kcal\n\nMakros:\nProtein: ${Math.round(proteinG)} g (${pP}%)\nKohlenhydrate: ${Math.round(carbG)} g (${cP}%)\nFett: ${Math.round(fatG)} g (${fP}%)`;
    navigator.clipboard.writeText(txt).then(()=>{ const b=document.getElementById('macroCopyBtn'); b.textContent='✓ Kopiert'; b.style.background='var(--green)'; b.style.borderColor='var(--green)'; b.style.color='#0E0E10'; setTimeout(()=>{ b.textContent='In Zwischenablage kopieren'; b.style.background=''; b.style.borderColor=''; b.style.color=''; },1800); });
  });
});

