document.getElementById('dashImportFile').addEventListener('change',e=>{
  const file=e.target.files[0]; if(!file) return;
  const reader=new FileReader();
  reader.onload=async ev=>{
    try{
      const imp=JSON.parse(ev.target.result);
      if(imp&&Array.isArray(imp.clients)&&typeof imp.entries==='object'){
        state=imp; await saveState(); trkCurrentClientId='';
        renderDash(); renderTrkClientSelect();
      } else alert('Ungültiges Dateiformat.');
    }catch(err){ alert('Datei konnte nicht gelesen werden.'); }
  };
  reader.readAsText(file); e.target.value='';
});

/* ============================================================
   TRACKER TAB
   ============================================================ */
function renderTrkClientSelect(){
