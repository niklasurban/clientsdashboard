<script>
/* ============================================================
   SHARED STATE
   ============================================================ */
const REGION_LABELS = {schulter:"Schulter",knie:"Knie",ruecken:"Rücken / LWS",huefte:"Hüfte",nacken:"Nacken / HWS",sprunggelenk:"Sprunggelenk",ganzkorper:"Ganzkörper / Allgemein"};
const PHASE_LABELS  = {phase1:"Phase 1 — Akut",phase2:"Phase 2 — Mobilität",phase3:"Phase 3 — Kraftaufbau",phase4:"Phase 4 — Return to Activity"};
const PHASE_PILL_CLS = {phase1:"p1",phase2:"p2",phase3:"p3",phase4:"p4"};
const EQUIP_LABELS  = {bw:"Eigenkörpergewicht",band:"Theraband",dumbbell:"Kurzhanteln",cable:"Kabelzug / Maschine"};

const PHASE_INFO = {
  phase1:{label:"Phase 1 — Akut",desc:"Fokus: Schmerzreduktion, sanfte Mobilisation, Aktivierung ohne relevanten Belastungsreiz.",nextCriteria:"Wechsel zu Phase 2, wenn: Schmerz in Ruhe ≤ 2/10, schmerzfreie Alltagsbewegungen, keine Schmerzzunahme nach Belastung."},
  phase2:{label:"Phase 2 — Mobilität & Stabilität",desc:"Fokus: Bewegungsausmaß zurückgewinnen, erste gezielte Stabilisationsreize.",nextCriteria:"Wechsel zu Phase 3, wenn: Schmerz bei Belastung ≤ 3/10, annähernd normales Bewegungsausmaß, saubere Bewegungskontrolle."},
  phase3:{label:"Phase 3 — Kraftaufbau",desc:"Fokus: Progressive Belastungssteigerung, funktionelle Kraft und Belastbarkeit.",nextCriteria:"Wechsel zu Phase 4, wenn: beschwerdefreie Ausführung unter Zusatzlast, symmetrische Kraft, keine Schmerzzunahme nach 24 Std."},
  phase4:{label:"Phase 4 — Return to Activity",desc:"Fokus: Sport-/alltagsspezifische Belastung, Rückkehr zur vollen Aktivität.",nextCriteria:"Volle Belastung bei: schmerzfreien dynamischen Bewegungen, voller Belastbarkeit, abschließender ärztlicher/physiotherapeutischer Freigabe."}
};

let state = {clients:[], entries:{}};
let trkCurrentClientId = "";
let hasStorage = false;

function genId(){ return 'id_'+Date.now()+'_'+Math.random().toString(36).slice(2,8); }
function esc(s){ return String(s||'').replace(/[&<>]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;'}[c])); }
function fmtN(n,d=1){ if(n===null||n===undefined||isNaN(n)) return '–'; return Number(n).toLocaleString('de-DE',{maximumFractionDigits:d,minimumFractionDigits:0}); }
function fmtDate(d){ const dt=new Date(d+'T00:00:00'); return isNaN(dt)?d:dt.toLocaleDateString('de-DE',{day:'2-digit',month:'2-digit',year:'2-digit'}); }

/* ============================================================
   STORAGE
   ============================================================ */
async function loadState(){
  // 1. Try localStorage (persistent across sessions)
  try{
    const raw = localStorage.getItem('niki-dashboard');
    if(raw){ hasStorage=true; return JSON.parse(raw); }
  }catch(e){}
  // 2. Try window.storage (artifact storage)
  if(window.storage){
    hasStorage=true;
    try{ const r=await window.storage.get('niki-dashboard',false); return r&&r.value?JSON.parse(r.value):{clients:[],entries:{}}; }
    catch(e){ return {clients:[],entries:{}}; }
  }
  hasStorage=false;
  return {clients:[],entries:{}};
}
async function saveState(){
  // Save to localStorage (primary)
  try{ localStorage.setItem('niki-dashboard', JSON.stringify(state)); hasStorage=true; }catch(e){}
  // Also save to window.storage if available
  if(window.storage){ try{ await window.storage.set('niki-dashboard',JSON.stringify(state),false); }catch(e){} }
}

/* ============================================================
   NAVIGATION
   ============================================================ */
document.querySelectorAll('.nav-tab').forEach(btn=>{
  btn.addEventListener('click',()=>{
    document.querySelectorAll('.nav-tab').forEach(b=>b.classList.remove('active'));
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('tab-'+btn.dataset.tab).classList.add('active');
    if(btn.dataset.tab==='dash') renderDash();
    if(btn.dataset.tab==='tracker') renderTrkClientSelect();
  });
});

function goToTab(tab, clientId){
  document.querySelectorAll('.nav-tab').forEach(b=>b.classList.remove('active'));
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelector('[data-tab='+tab+']').classList.add('active');
  document.getElementById('tab-'+tab).classList.add('active');
  if(tab==='tracker'&&clientId){
    renderTrkClientSelect();
    document.getElementById('trkClientSelect').value=clientId;
    trkSelectClient(clientId);
  }
}

/* ============================================================
   DASHBOARD TAB
   ============================================================ */
function renderDash(){
  const note = document.getElementById('dashStorageNote');
  if(hasStorage){ note.className='note ok'; note.textContent='● Automatische Speicherung aktiv — Daten bleiben auch nach dem Schließen erhalten.'; }
  else { note.className='note warn'; note.textContent='● Keine automatische Speicherung erkannt — bitte regelmäßig exportieren.'; }

  const kpiEl = document.getElementById('dashKpi');
  const total = state.clients.length;
  const phases = {phase1:0,phase2:0,phase3:0,phase4:0};
  state.clients.forEach(c=>{ if(phases[c.phase]!==undefined) phases[c.phase]++; });
  const totalEntries = Object.values(state.entries).reduce((a,b)=>a+b.length,0);
  kpiEl.innerHTML = `
    <div class="kpi-block"><div class="kpi-label">Klient:innen gesamt</div><div class="kpi-num">${total}</div><div class="kpi-sub">aktiv betreut</div></div>
    <div class="kpi-block"><div class="kpi-label">Einträge gesamt</div><div class="kpi-num">${totalEntries}</div><div class="kpi-sub">Verlaufsdaten</div></div>
    <div class="kpi-block"><div class="kpi-label">Phase 1–2</div><div class="kpi-num">${phases.phase1+phases.phase2}</div><div class="kpi-sub">Akut & Mobilität</div></div>
    <div class="kpi-block"><div class="kpi-label">Phase 3–4</div><div class="kpi-num">${phases.phase3+phases.phase4}</div><div class="kpi-sub">Kraft & Return</div></div>
  `;

  const ccEl = document.getElementById('clientCards');
  if(state.clients.length===0){
    ccEl.innerHTML = '<div class="empty-state" style="grid-column:1/-1">Noch keine Klient:innen angelegt. Trage die erste Person links ein.</div>';
    return;
  }
  ccEl.innerHTML = state.clients.map(c=>{
    const entries = (state.entries[c.id]||[]).slice().sort((a,b)=>a.date.localeCompare(b.date));
    const lastPain = entries.length ? entries.slice(-1)[0].pain : null;
    const lastWeight = entries.filter(e=>e.weight!==null).slice(-1)[0]?.weight ?? null;
    const entryCount = entries.length;
    return `
      <div class="client-card">
        <span class="phase-pill ${PHASE_PILL_CLS[c.phase]}">${PHASE_LABELS[c.phase]}</span>
        <div class="cc-name">${esc(c.name)}</div>
        <div class="cc-meta">${REGION_LABELS[c.region]} · ${entryCount} Einträge</div>
        <div class="cc-stats">
          <div class="cc-stat"><div class="cc-stat-label">Letzter Schmerz</div><div class="cc-stat-val" style="color:${lastPain===null?'var(--ink-soft)':lastPain<=3?'var(--green)':lastPain<=6?'var(--amber)':'var(--rust)'}">${lastPain!==null?lastPain+'/10':'–'}</div></div>
          <div class="cc-stat"><div class="cc-stat-label">Letztes Gewicht</div><div class="cc-stat-val">${lastWeight!==null?fmtN(lastWeight)+' kg':'–'}</div></div>
        </div>
        <div class="cc-actions">
          <button onclick="goToTab('tracker','${c.id}')">Tracker öffnen</button>
          <button onclick="prefillPlan('${esc(c.name)}','${c.region}','${c.phase}')">Plan erstellen</button>
        </div>
      </div>
    `;
  }).join('');
}

document.getElementById('dashAddClientBtn').addEventListener('click', async ()=>{
  const name = document.getElementById('dashNewName').value.trim();
  const note = document.getElementById('dashAddNote');
  if(!name){ note.className='note'; note.textContent='Bitte Name eingeben.'; note.style.color='var(--rust)'; note.style.borderTop='none'; note.style.paddingTop='0'; return; }
