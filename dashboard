function bindPhaseUpdate(){
  const sel=document.getElementById('trkPhaseUpdate');
  if(!sel) return;
  sel.addEventListener('change',async e=>{ const c=state.clients.find(c=>c.id===trkCurrentClientId); if(c){c.phase=e.target.value; await saveState(); renderDash();} });
}

