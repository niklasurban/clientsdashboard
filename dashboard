  const up=entries.filter(e=>e.umfangValue!==null).map(e=>({date:e.date,value:e.umfangValue}));
  const kp=entries.filter(e=>e.kraftValue!==null).map(e=>({date:e.date,value:e.kraftValue}));
  const lastUL=up.length?entries.filter(e=>e.umfangValue!==null).slice(-1)[0].umfangLabel:'';
